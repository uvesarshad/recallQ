{
  "name": "recallq-workspace",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "dev": "turbo run dev --filter=@recall/web",
    "dev:ext": "turbo run dev --filter=@recall/extension",
    "build": "turbo run build --filter=@recall/web",
    "build:ext": "turbo run build --filter=@recall/extension",
    "build:all": "turbo run build",
    "zip:ext": "pnpm --filter @recall/extension zip",
    "start": "turbo run start --filter=@recall/web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --filter=@recall/web",
    "db:migrate": "node scripts/migrate.js",
    "db:migrate:latest": "node scripts/migrate-latest.js",
    "admin:jobs": "node scripts/admin-jobs.mjs",
    "openapi:generate": "node scripts/generate-openapi.mjs",
    "recall": "node scripts/recall-cli.mjs",
    "mcp": "node scripts/recall-mcp-server.mjs",
    "worker:enrich": "pnpm --filter @recall/web worker:enrich",
    "worker:jobs": "pnpm --filter @recall/web worker:jobs",
    "worker:reminders": "pnpm --filter @recall/web worker:reminders",
    "telegram:webhook": "node scripts/register-telegram-webhook.js"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "pg": "latest",
    "turbo": "^2.5.4"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "~18.3.12",
      "@types/react-dom": "~18.3.5"
    }
  }
}
