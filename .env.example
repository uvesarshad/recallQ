DATABASE_URL=postgresql://user:pass@localhost:5432/database
AUTH_SECRET=replace-me-run-openssl-rand-base64-32
AUTH_URL=
NEXTAUTH_URL=
APP_URL=http://localhost:3000
APP_DOMAIN=localhost
SELF_HOSTED=false
FILES_BASE_PATH=/tmp/recall/files
INTERNAL_INGEST_TOKEN=replace-me
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_STARTER_YEARLY_ID=
RAZORPAY_PLAN_PRO_YEARLY_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=RecallBot
TELEGRAM_WEBHOOK_SECRET=replace-me
RESEND_API_KEY=
RESEND_INBOUND_SECRET=replace-me
RESEND_WEBHOOK_SECRET=
RESEND_FROM_EMAIL=no-reply@example.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
DEV_BYPASS_LOGIN=false

# LLM provider (google | openai | anthropic | xai). Default: google
LLM_PROVIDER=google

# Override the default model for the chosen provider (optional)
# LLM_MODEL=gpt-4o

# Required if LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Required if LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Required if LLM_PROVIDER=xai (Grok)
# XAI_API_KEY=xai-...

# Optional: custom base URL for any OpenAI-compatible endpoint (Groq, Ollama, etc.)
# LLM_BASE_URL=https://api.groq.com/openai/v1
