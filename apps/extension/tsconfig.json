{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "types": ["chrome"]
  },
  "include": [".wxt/wxt.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", ".output", ".wxt/types"]
}
